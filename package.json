{
  "name": "vinfast-sales-bot",
  "version": "0.1.0",
  "private": true,
  "description": "WhatsApp Sales Admin Bot for VinFast dealer (PT Otomobil Multi Artha)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "karyawan:seed": "tsx src/cli/karyawan-seed.ts",
    "karyawan:list": "tsx src/cli/karyawan-list.ts",
    "karyawan:sync": "tsx src/cli/sync-karyawan.ts",
    "karyawan:sync:force": "tsx src/cli/sync-karyawan.ts --force",
    "spk:sync": "tsx src/cli/sync-spk.ts",
    "drive:migrate": "tsx src/cli/drive-migrate.ts",
    "drive:migrate:dry": "tsx src/cli/drive-migrate.ts --dry",
    "ocr:test": "tsx scripts/test-ocr.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "axios": "^1.7.9",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "exceljs": "^4.4.0",
    "googleapis": "^144.0.0",
    "hono": "^4.6.14",
    "ioredis": "^5.4.2",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
