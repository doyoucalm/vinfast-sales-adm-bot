# ──────────────────────────────────────────────────────────
# VinFast Bot — Environment Configuration Template
# Copy ke .env dan isi value real (.env GITIGNORED, jangan commit!)
# ──────────────────────────────────────────────────────────

NODE_ENV=production
LOG_LEVEL=info
PORT=3001

# ───── Domain ─────
PUBLIC_DOMAIN=vinfast.caricreatormu.my.id

# ───── PostgreSQL (port 5433 di host) ─────
DATABASE_URL=postgresql://vinfast:CHANGEME@vinfast-db:5432/vinfast_bot
DB_PASSWORD=CHANGEME

# ───── Redis (port 6380 di host) ─────
REDIS_URL=redis://vinfast-redis:6379

# ───── Microsoft SharePoint (READ-ONLY via REST API) ─────
MS_TENANT_ID=1f2b5b87-aa36-4655-9000-f099ad69d106
MS_CLIENT_ID=14d82eec-204b-4c2f-b7e8-296a70dab67e
MS_SCOPE=https://amapartner.sharepoint.com/AllSites.Read offline_access
SP_RESOURCE=https://amapartner.sharepoint.com
SP_SITE_PATH=/sites/VinFast
SP_SITE_ID=amapartner.sharepoint.com,88323408-d5f7-46f4-9dec-d2b928a44db9,8d84178b-431b-4665-8281-808a8d124643
SP_TOKEN_CACHE=/opt/sales-bot/credentials/sp-token.json
SP_POLL_INTERVAL_SEC=120

# Path file Excel master di SharePoint
SP_FILE_JURNAL_SALES=/sites/VinFast/Shared Documents/Jurnal/Sales/Jurnal Sales Mobil.xlsx
SP_FILE_JURNAL_OMPANG=/sites/VinFast/Shared Documents/Jurnal/Sales/Jurnal Ompang.xlsx
SP_FILE_DOKUMEN_DO=/sites/VinFast/Shared Documents/Jurnal/Sales/DOKUMEN DO.xlsx
SP_FILE_DB_MOBIL=/sites/VinFast/Shared Documents/CORE DATABASE/Operational/DB_MOBIL.xlsx

# ───── OpenRouter (LLM gateway) ─────
# Daftar di openrouter.ai, top-up balance, generate key
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NLU=deepseek/deepseek-chat
LLM_MODEL_OCR=google/gemini-flash-1.5
LLM_TIMEOUT_MS=5000
LLM_MAX_RETRIES=1
LLM_CACHE_TTL_SEC=3600
LLM_CIRCUIT_BREAKER_THRESHOLD=3
LLM_CIRCUIT_BREAKER_COOLDOWN_SEC=300

# ───── Google Workspace (WRITE side — masih BELUM SETUP per 12 Mei 2026) ─────
# Setup di console.cloud.google.com dengan account automobilvinfast@gmail.com
GOOGLE_SA_KEY_PATH=/opt/sales-bot/credentials/google-sa.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_SHEETS_INBOX_ID=
GOOGLE_DOCAI_PROJECT_ID=vinfast-sales-bot
GOOGLE_DOCAI_LOCATION=asia-southeast1
GOOGLE_DOCAI_KTP_PROCESSOR_ID=
GOOGLE_DOCAI_FORM_PROCESSOR_ID=

# ───── Evolution API ─────
# Reuse instance container existing di VPS (port 8080 internal)
EVOLUTION_API_URL=http://evolution_api:8080
EVOLUTION_API_KEY=CHANGEME
EVOLUTION_INSTANCE=vinfast-bot
EVOLUTION_WEBHOOK_URL=https://vinfast.caricreatormu.my.id/webhook/wa

# ───── Webhook security ─────
WEBHOOK_HMAC_SECRET=CHANGEME_random_32_chars_minimum
WEBHOOK_API_KEY=CHANGEME_random_32_chars_minimum

# ───── Admin & Notifications ─────
# Nomor admin untuk notifikasi alert (format 628xxxxxxxxxx)
ADMIN_WA_NUMBERS=628xxxxxxxxxx
ADMIN_EMAIL=Lucky@amapartner.org

# ───── Rate Limits ─────
RATE_LIMIT_USER_PER_MIN=30
RATE_LIMIT_GUEST_PER_MIN=10
RATE_LIMIT_GLOBAL_PER_SEC=50

# ───── Conversational State ─────
SPK_INTAKE_TTL_SEC=1800
